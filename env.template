# ──────────────────────────────────────────────────────────
#  Kinsu Health Backend - Environment Configuration Template
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values

# ── Application ────────────────────────────────────────────
PROJECT_NAME=Kinsu Health API
API_V1_PREFIX=/api/v1
BASE_URL=http://localhost:8000

# ── Database ───────────────────────────────────────────────
# For PostgreSQL (recommended for production):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kinsu_health

# For SQLite (development only):
# DATABASE_URL=sqlite+aiosqlite:///./kinsu.db

# ── Firebase ───────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.0\.1)(:\d+)?$

# ── Storage ────────────────────────────────────────────────
# Options: "local" or "s3"
STORAGE_BACKEND=local
FILE_STORAGE_PATH=./uploads

# ── AWS S3 (only needed if STORAGE_BACKEND=s3) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=kinsu-health-vault
S3_PRESIGNED_URL_EXPIRATION=3600

# ── Logging ────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Options: "development" or "json"
# Use "development" for colored human-readable logs
# Use "json" for structured JSON logs in production
LOG_FORMAT=development
